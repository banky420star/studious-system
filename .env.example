# Postgres (used by both docker and local dev)
DATABASE_URL=postgres://crmuser:crmpass@localhost:5432/wa_crm

# API Server
API_PORT=3000
INTERNAL_API_SECRET=dev-secret-change-me

# WhatsApp Worker internal send endpoint
WORKER_SEND_URL=http://localhost:3001/send

# Ollama (local or docker)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=direct-crm-agent

# Redis (for future queues)
REDIS_URL=redis://localhost:6379

# Optional: Business display name for logs
BUSINESS_NAME=ACME Store
